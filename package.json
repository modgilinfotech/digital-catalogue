{
  "name": "digital-catalogue",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-tenant digital catalogue for small retail/wholesale shops, running on Cloudflare Pages + D1 + R2 (free tier).",
  "scripts": {
    "dev": "wrangler pages dev public --d1=DB --r2=PRODUCT_IMAGES",
    "deploy": "wrangler pages deploy public",
    "db:migrate:local": "wrangler d1 execute digital-catalogue-db --local --file=./migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute digital-catalogue-db --remote --file=./migrations/0001_init.sql",
    "db:seed:local": "wrangler d1 execute digital-catalogue-db --local --file=./seed.sql",
    "db:seed:remote": "wrangler d1 execute digital-catalogue-db --remote --file=./seed.sql"
  },
  "devDependencies": {
    "wrangler": "^3.90.0"
  }
}
